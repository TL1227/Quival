<UserControl x:Class="QuivalCombatTestWPF.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuivalCombatTestWPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Label VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="1" Grid.Column="1" FontSize="90">Quival</Label>

        <StackPanel Margin="30,0" Grid.Row="1" Grid.Column="1">
            <Button FontSize="20" Content="Random Match" x:Name="StartMatchButton"></Button>
            <Button FontSize="20" Content="Join Room" x:Name="FindRoomButton"></Button>
            <Button FontSize="20" Content="Create Room" x:Name="CreateRoomButton"></Button>
            <Button FontSize="20" Content="Quit" x:Name="QuitGameButton"></Button>
        </StackPanel>

    </Grid>
</UserControl>
