<Window x:Class="QuivalCombatTestWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuivalCombatTestWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920">
    
    <Grid Margin="10" x:Name="BattleField">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="0.5*"></RowDefinition>
            <RowDefinition x:Name="CombatZoneRow" Height="1.3*"/>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition x:Name="CombatZoneColumn" Width="4*"/>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label x:Name="OpponentLifeLabel" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Background="CornflowerBlue" FontSize="40" Content="20"></Label>
        <local:Spellstream x:Name="SpellstreamZone" Grid.Column="1" Grid.Row="1"/>
        <local:CombatZone x:Name="CombatZone" Grid.Column="1" Grid.Row="2"/>
        <local:HandZone x:Name="HandZone" Grid.Column="1" Grid.Row="3"/>
        <Label x:Name="PlayerLifeLabel" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" Background="CornflowerBlue" FontSize="40" Content="20"></Label>

        <Button 
            x:Name="SpellStreamCastButton" 
            Margin="5"
            Width="100" Height="40"
            Grid.Row="3" Grid.Column="2" 
            Click="SpellStreamCastButton_Click">Cast SpellStream
        </Button>

    </Grid>
</Window>
