<Window x:Class="QuivalCombatTestWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuivalCombatTestWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280">
    
    <Grid x:Name="BattleField">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition x:Name="CombatZoneRow" Height="1.3*"/>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition x:Name="CombatZoneColumn" Width="4*"/>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <local:CombatZone x:Name="CombatZone" Grid.Column="1" Grid.Row="1"/>
        <local:HandZone x:Name="HandZone" Grid.Column="1" Grid.Row="2"/>

        <Button 
            x:Name="SpellStreamCastButton" 
            Margin="50,80,50,80" 
            Grid.Row="2" Grid.Column="2" 
            Click="SpellStreamCastButton_Click">Cast SpellStream
        </Button>

    </Grid>
</Window>
