<UserControl x:Class="QuivalCombatTestWPF.HandCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuivalCombatTestWPF"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="220">
    <Grid x:Name="CardBackground" Margin="10" Background="Coral">
        <Grid x:Name="CardContent" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="1.6*"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid Name="TopGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="25"/>
                </Grid.ColumnDefinitions>
                <Label Margin="0,0,0,5" Background="Cornsilk" Grid.Column="0" x:Name="CardNameLabel" Content="Keen Bean" FontSize="18"></Label>
                <Label Margin="0,0,0,5" Background="Cornsilk" Grid.Column="2" x:Name="CostContent" Content="3" FontSize="18"></Label>
            </Grid>

            <DockPanel Grid.Row="1" Background="White">
                <Image x:Name="CardImage"></Image>
            </DockPanel>

            <DockPanel x:Name="TextPanel" Grid.Row="2" Background="LightGray">
                <TextBlock Margin="5" x:Name="CardDescriptionLabel" TextWrapping="WrapWithOverflow" FontSize="20" >
                    <Italic>DoubleUp 3</Italic>.<LineBreak/>If Keen Bean attacks on round 3, here is somethin more stuff what about this buddy time this is something else I'd like to put on the text. And another thing
                </TextBlock>
            </DockPanel>

            <Grid Margin="0,8,0,0" Grid.Row="3" Name="BottomGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" x:Name="GlobalId" Content="ALP001" FontSize="12" VerticalAlignment="Bottom"/>
                <Label Background="Cornsilk" Grid.Column="1" x:Name="AttackLabel" Content="3" FontSize="20" />
                <Label Background="Cornsilk" Grid.Column="2" x:Name="Divider" Content="/" FontSize="20"/>
                <Label Background="Cornsilk" Grid.Column="3" x:Name="HealthLabel" Content="4" FontSize="20"/>
            </Grid>
        </Grid>
        <DockPanel x:Name="Overlay" Background="Aquamarine" Opacity="0"></DockPanel>
    </Grid>
</UserControl>
