<UserControl x:Class="QuivalCombatTestWPF.BoardCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuivalCombatTestWPF"
             mc:Ignorable="d" 
             d:DesignHeight="140" d:DesignWidth="180"
             Width="180" Height="160"
             x:Name="Root">
    <Border x:Name="Border" >
        <Grid x:Name="CardBackground" Background="Coral" Margin="5" >
            <Grid x:Name="CardContent" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Grid Name="TopGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Margin="0,5,0,0" Background="Cornsilk" Grid.ColumnSpan="3" Grid.Column="0" x:Name="CardNameLabel" Content="Keen Bean" FontSize="12"></Label>
                </Grid>

                <Border Grid.Row="1" Background="White" BorderBrush="Black" BorderThickness="0">
                        <Image x:Name="CardImage" Stretch="UniformToFill"></Image>
                </Border>

                <Grid Grid.Row="2" Name="BottomGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Margin="0,0,0,5" Background="Black" Foreground="White" Grid.Column="0" x:Name="DebugId" FontSize="12"/>
                    <Label Margin="0,0,0,5" Background="Cornsilk" Grid.Column="1" x:Name="AttackLabel" Content="3" FontSize="12"/>
                    <Label Margin="0,0,0,5" Background="Cornsilk" Grid.Column="2" x:Name="Divider" Content="/" FontSize="12"/>
                    <Label Margin="0,0,0,5" Background="Cornsilk" Grid.Column="3" x:Name="HealthLabel" Content="4" FontSize="12"/>
                </Grid>
            </Grid>
            <DockPanel x:Name="Overlay" Background="Aquamarine" Opacity="0"></DockPanel>
            <DockPanel x:Name="SelectedOverlay" Background="Coral" Opacity="0"></DockPanel>
            <DockPanel x:Name="FlashOverlay" Background="Aquamarine" Opacity="0"></DockPanel>
        </Grid>
    </Border>
</UserControl>
