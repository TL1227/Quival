<UserControl x:Class="QuivalCombatTestWPF.Spellstream"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuivalCombatTestWPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="SpellStreamGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="QuickSlot"></ColumnDefinition>
            <ColumnDefinition x:Name="Slot1"></ColumnDefinition>
            <ColumnDefinition x:Name="Slot2"></ColumnDefinition>
            <ColumnDefinition x:Name="Slot3"></ColumnDefinition>
            <ColumnDefinition x:Name="Slot4"></ColumnDefinition>
            <ColumnDefinition x:Name="Slot5"></ColumnDefinition>
            <ColumnDefinition x:Name="SlowSlot"></ColumnDefinition>
        </Grid.ColumnDefinitions> 
    </Grid>
</UserControl>
